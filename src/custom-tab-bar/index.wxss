.tabbar {
  position: fixed;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 999;
  display: grid;
  box-sizing: content-box;
  height: 58px;
  grid-template-columns: repeat(5, 1fr);
  padding-bottom: env(safe-area-inset-bottom);
  border-top: 1px solid rgba(28, 31, 43, .08);
  background: rgba(255, 255, 255, .98);
  box-shadow: 0 -5px 18px rgba(28, 31, 43, .07);
}

.tabbar button {
  position: relative;
  display: flex;
  min-width: 0;
  height: 58px;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 3px;
  margin: 0;
  padding: 0;
  color: #9396a7;
  font-size: 10px;
  line-height: 1;
  border: 0;
  border-radius: 0;
  background: transparent;
}

.tabbar button::after { display: none; }
.tabbar .tab.active { color: #5856e0; font-weight: 700; }
.nav-icon { position: relative; width: 23px; height: 23px; color: currentColor; }

.icon-file {
  box-sizing: border-box;
  width: 18px;
  height: 21px;
  border: 2px solid currentColor;
  border-radius: 3px;
}
.icon-file::before {
  position: absolute;
  top: -2px;
  right: -2px;
  width: 6px;
  height: 6px;
  content: '';
  border-bottom: 2px solid currentColor;
  border-left: 2px solid currentColor;
  background: #fff;
}
.file-line,
.icon-file::after {
  position: absolute;
  right: 3px;
  left: 3px;
  height: 2px;
  content: '';
  border-radius: 2px;
  background: currentColor;
}
.file-line { top: 9px; }
.icon-file::after { top: 14px; }

.icon-template { display: grid; width: 21px; height: 21px; grid-template-columns: 1fr 1fr; gap: 3px; }
.icon-template view { border: 2px solid currentColor; border-radius: 3px; }

.sign-disc .sign-stroke {
  position: absolute;
  top: 10px;
  left: 2px;
  width: 18px;
  height: 8px;
  border-bottom: 2px solid currentColor;
  border-radius: 50%;
  transform: rotate(-13deg);
}
.sign-disc .sign-stroke::after {
  position: absolute;
  right: -1px;
  bottom: -4px;
  width: 7px;
  height: 2px;
  content: '';
  border-radius: 2px;
  background: currentColor;
  transform: rotate(22deg);
}

.icon-signature-library {
  box-sizing: border-box;
  width: 21px;
  height: 22px;
  border: 2px solid currentColor;
  border-radius: 4px;
}
.library-line { position:absolute;left:4px;width:9px;height:2px;border-radius:2px;background:currentColor; }
.library-line.top { top:4px; }
.library-line.bottom { top:8px;width:7px; }
.library-sign { position:absolute;right:2px;bottom:3px;width:10px;height:5px;border-bottom:2px solid currentColor;border-radius:50%;transform:rotate(-12deg); }

.icon-person .person-head {
  position: absolute;
  top: 1px;
  left: 8px;
  width: 7px;
  height: 7px;
  border: 2px solid currentColor;
  border-radius: 50%;
}
.icon-person .person-body {
  position: absolute;
  right: 2px;
  bottom: 1px;
  left: 2px;
  height: 9px;
  border: 2px solid currentColor;
  border-radius: 10px 10px 3px 3px;
}

.tabbar .sign-action { color: #5856e0; font-weight: 800; }
.sign-disc {
  position: relative;
  display: flex;
  width: 42px;
  height: 34px;
  align-items: center;
  justify-content: center;
  color: #fff;
  border-radius: 8px;
  background: #5856e0;
  box-shadow: 0 5px 13px rgba(88, 86, 224, .32);
}
.sign-disc .sign-stroke { top: 8px; left: 10px; width: 22px; }

.tabbar.dark {
  border-top-color: rgba(255, 255, 255, .08);
  background: rgba(25, 26, 34, .98);
  box-shadow: 0 -5px 18px rgba(0, 0, 0, .22);
}
.tabbar.dark button { color: #8d91a2; }
.tabbar.dark .tab.active { color: #8f8cff; }
.tabbar.dark .icon-file::before { background: #191a22; }
.tabbar.dark .sign-action { color: #8f8cff; }
