{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowJs": true,
    "checkJs": false,
    "noEmit": true,
    "strict": false,
    "skipLibCheck": true,
    "types": ["@dcloudio/types", "vite/client"]
  },
  "include": ["src/**/*.js", "src/**/*.vue", "vite.config.js"]
}
